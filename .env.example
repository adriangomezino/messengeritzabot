# Variables de entorno para desarrollo local
# Copiar a .env y completar con tus valores

# Meta Messenger
META_VERIFY_TOKEN=tu_token_secreto_para_webhook
META_PAGE_ACCESS_TOKEN=EAAG..._tu_token_de_pagina

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-tu_api_key_de_openrouter
OPENROUTER_MODEL=openrouter/free

# OpenClaw
OPENCLAW_API_URL=https://server.itzamnaenergia.com
# OPENCLAW_API_KEY=openc-...  # Solo si OpenClaw requiere autenticación

# Servidor
PORT=8000
DEBUG=True